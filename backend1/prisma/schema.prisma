// ============================================================
// SAASA - Candidate Platform Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EmploymentStatus {
  EMPLOYED
  UNEMPLOYED
  FREELANCING
  STUDENT
  OTHER
}

enum SalaryType {
  MONTHLY
  ANNUAL
  HOURLY
  DAILY
}

enum WorkMode {
  REMOTE
  ON_SITE
  HYBRID
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  NATIVE
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  ASSESSMENT
  INTERVIEW
  FINAL_DECISION
  SELECTED
  REJECTED
}

enum NotificationType {
  UPDATE
  NEW
  REMINDER
  ALERT
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum CourseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

// ============================================================
// AUTH & VERIFICATION
// ============================================================

model Candidate {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  whatsappNumber    String    @unique
  countryCode       String    @default("+91")
  isVerified        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  otpVerifications  OtpVerification[]
  profile           CandidateProfile?
  resume            Resume?
  resumeVersions    ResumeVersion[]
  educations        Education[]
  workExperiences   WorkExperience[]
  skills            CandidateSkill[]
  languages         CandidateLanguage[]
  careerPreferences CareerPreferences?
  summary           CandidateSummary?
  gapExplanation    CandidateGapExplanation?
  internship        CandidateInternship?
  portfolioLinks    CandidatePortfolioLinks?
  project           CandidateProject?
  academicAchievement CandidateAcademicAchievement?
  competitiveExam   CandidateCompetitiveExam?
  certifications    CandidateCertification[]
  accomplishments   CandidateAccomplishment[]
  visaWorkAuthorization CandidateVisaWorkAuthorization?
  vaccination       CandidateVaccination?
  applications      Application[]
  savedJobs         SavedJob[]
  notifications     Notification[]
  dashboardStats    DashboardStats?
  courseEnrollments CourseEnrollment[]
  cvAnalysis        CvAnalysis?

  @@map("candidates")
}

model OtpVerification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String    @db.ObjectId
  otp         String
  status      OtpStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

// ============================================================
// PERSONAL PROFILE
// ============================================================

model CandidateProfile {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  candidateId         String          @unique @db.ObjectId
  fullName            String
  email               String          @unique
  isEmailVerified     Boolean         @default(false)
  phoneNumber         String?
  alternatePhone      String?
  profilePhotoUrl     String?
  gender              Gender?
  dateOfBirth         DateTime?
  maritalStatus       MaritalStatus?
  address             String?
  city                String?
  country             String?
  nationality         String?
  passportNumber      String?
  linkedinUrl         String?
  employmentStatus    EmploymentStatus?
  profileCompleteness Int             @default(0)
  skillsAdditionalNotes String?      // Additional notes for skills section
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  candidate           Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

// ============================================================
// RESUME
// ============================================================

model Resume {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId  String   @unique @db.ObjectId
  fileName     String
  fileUrl      String
  fileSize     Int?     // in bytes
  mimeType     String?
  atsScore     Int?     // 0-100
  aiAnalyzed   Boolean  @default(false)
  resumeJson   Json?    // Structured resume data in JSON format
  resumeHtml   String?  // HTML content for WYSIWYG editor
  templateId   String?  // Template identifier for consistent rendering
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]

  @@map("resumes")
}

// ============================================================
// RESUME VERSIONS
// ============================================================

model ResumeVersion {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId  String   @db.ObjectId
  resumeId     String   @db.ObjectId
  resumeJson   Json?    // Snapshot of resume JSON at this version
  resumeHtml   String?  // Snapshot of resume HTML at this version
  templateId   String?  // Template identifier
  createdAt    DateTime @default(now())

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("resume_versions")
  @@index([candidateId])
  @@index([resumeId])
}

// ============================================================
// EDUCATION
// ============================================================

model Education {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId    String    @db.ObjectId
  educationLevel String?   // High School, Diploma, Bachelor's, Master's, etc.
  degree         String
  institution    String
  specialization String?   // Field of Study / Major
  startYear      Int
  endYear        Int?
  isOngoing      Boolean   @default(false)
  grade          String?
  modeOfStudy    String?   // Full-time, Part-time, Online, etc.
  courseDuration String?   // e.g., "3 years"
  description    String?
  documents      String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("educations")
}

// ============================================================
// SKILLS
// ============================================================

model Skill {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  name             String           @unique
  category         String?
  createdAt        DateTime         @default(now())

  candidateSkills  CandidateSkill[]
  jobSkills        JobSkill[]

  @@map("skills")
}

model CandidateSkill {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  candidateId   String      @db.ObjectId
  skillId       String      @db.ObjectId
  proficiency   Proficiency @default(INTERMEDIATE)
  isAiSuggested Boolean     @default(false)
  yearsOfExp    Float?
  createdAt     DateTime    @default(now())

  candidate     Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill         Skill       @relation(fields: [skillId], references: [id])

  @@unique([candidateId, skillId])
  @@map("candidate_skills")
}

// ============================================================
// LANGUAGES
// ============================================================

model CandidateLanguage {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String      @db.ObjectId
  name        String
  proficiency Proficiency @default(INTERMEDIATE)
  canSpeak    Boolean     @default(false)
  canRead     Boolean     @default(false)
  canWrite    Boolean     @default(false)
  documents   String[]    @default([]) // URLs to uploaded certificate/document files
  createdAt   DateTime    @default(now())

  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, name])
  @@map("candidate_languages")
}

// ============================================================
// WORK EXPERIENCE
// ============================================================

model WorkExperience {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId      String    @db.ObjectId
  jobTitle         String
  company          String
  workLocation     String?
  workMode         WorkMode?
  startDate        DateTime
  endDate          DateTime?
  isCurrentJob     Boolean   @default(false)
  responsibilities String?   // Rich text / markdown
  industry         String?
  employmentType   EmploymentType?
  numberOfReportees String?
  companyProfile   String?
  companyTurnover  String?
  achievements     String?
  workSkills       String[]  @default([])
  documents        String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("work_experiences")
}

// ============================================================
// CAREER PREFERENCES
// ============================================================

model CareerPreferences {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId         String    @unique @db.ObjectId

  // Current
  currentCurrency     String?   @default("USD")
  currentSalaryType   SalaryType?
  currentSalary       Float?
  currentLocation     String?
  currentBenefits     String[]  @default([])

  // Preferred - Role & Domain
  preferredRoles      String[]  @default([])
  preferredIndustry   String?
  functionalArea      String?
  
  // Preferred - Job Type & Work Mode
  jobTypes            String[]  @default([])
  preferredWorkMode   WorkMode?
  
  // Preferred - Location
  preferredLocations  String[]  @default([])
  relocationPreference String?
  
  // Preferred - Salary
  preferredCurrency   String?   @default("USD")
  preferredSalaryType SalaryType?
  preferredSalary     Float?
  preferredBenefits   String[]  @default([])

  // Availability
  availabilityToStart String?
  noticePeriodDays    Int?
  noticePeriod        String?
  openToRelocation    Boolean   @default(false)
  
  // Passport numbers by location
  passportNumbersByLocation Json?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("career_preferences")
}

model CandidateSummary {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String    @unique @db.ObjectId
  summaryText String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_summaries")
}

model CandidateGapExplanation {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId      String    @unique @db.ObjectId
  gapCategory      String
  reasonForGap     String
  gapDuration      String
  selectedSkills   String[]  @default([])
  coursesText      String?
  preferredSupport Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_gap_explanations")
}

model CandidateInternship {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId      String    @unique @db.ObjectId
  internshipTitle  String
  companyName      String
  internshipType   String?
  domainDepartment String?
  startDate        DateTime?
  endDate          DateTime?
  currentlyWorking Boolean   @default(false)
  location         String?
  workMode         String?
  responsibilities String?
  learnings        String?
  skills           String[]  @default([])
  documents        String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_internships")
}

model CandidatePortfolioLinks {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String    @unique @db.ObjectId
  links       Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_portfolio_links")
}

// ============================================================
// PROJECTS & ACHIEVEMENTS
// ============================================================

model CandidateProject {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId        String    @unique @db.ObjectId
  projectTitle       String
  projectType        String
  organizationClient String?
  currentlyWorking   Boolean   @default(false)
  startDate          DateTime?
  endDate            DateTime?
  projectDescription String?
  responsibilities   String?
  technologies       String[]  @default([])
  projectOutcome     String?
  projectLink        String?
  documents          String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_projects")
}

model CandidateAcademicAchievement {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId      String    @unique @db.ObjectId
  achievementTitle String
  awardedBy        String
  yearReceived     String
  categoryType     String?
  description      String?
  documents        String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_academic_achievements")
}

model CandidateCompetitiveExam {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId     String    @unique @db.ObjectId
  examName        String
  yearTaken       String
  resultStatus    String
  scoreMarks      String?
  scoreType       String?
  validUntil      String?
  additionalNotes String?
  documents       String[]  @default([]) // URLs to uploaded certificate/document files
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_competitive_exams")
}

model CandidateCertification {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId         String    @db.ObjectId
  certificationName   String
  issuingOrganization String
  issueDate           String
  expiryDate          String?
  doesNotExpire       Boolean   @default(false)
  credentialId        String?
  credentialUrl       String?
  certificateFile     String?
  documents           String[]  @default([]) // URLs to uploaded certificate/document files
  description         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_certifications")
}

model CandidateAccomplishment {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId        String    @db.ObjectId
  title              String
  category           String
  organization       String?
  achievementDate    String
  description        String?
  supportingDocument String?
  documents          String[]  @default([]) // URLs to uploaded supporting documents
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_accomplishments")
}

model CandidateVisaWorkAuthorization {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId            String    @unique @db.ObjectId
  selectedDestination    String?
  visaDetailsInitial     Json?
  visaDetailsExpected    Json?
  visaWorkpermitRequired String?
  openForAll             Boolean   @default(false)
  additionalRemarks      String?
  visaEntries            Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  candidate              Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_visa_work_authorizations")
}

model CandidateVaccination {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  candidateId         String    @unique @db.ObjectId
  vaccinationStatus   String
  vaccineType         String?
  lastVaccinationDate String?
  certificate         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_vaccinations")
}

// ============================================================
// JOBS
// ============================================================

model Company {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  logoUrl     String?
  website     String?
  industry    String?
  overview    String?
  location    String?
  createdAt   DateTime @default(now())

  jobs        Job[]

  @@map("companies")
}

// ── CLIENT (shared with backendphase2) ──
// backendphase2 stores clients in the `clients` collection.
// We add a compatible model so backend1 can read jobs created from backendphase2.
model Client {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  companyName   String
  industry      String?
  website       String?
  logo          String?
  location      String?
  status        String?
  assignedToId  String?   @db.ObjectId

  jobs Job[]

  @@map("clients")
}

model Job {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  // backend1's original schema uses `companyId` (companies collection).
  // When jobs are created from backendphase2, they usually include `clientId` (clients collection).
  companyId        String?        @db.ObjectId
  title            String
  location         String?

  // Compatible with backendphase2 job documents
  clientId              String?        @db.ObjectId
  description           String?
  overview              String?
  keyResponsibilities    String[]       @default([])
  preferredSkills       String[]       @default([])
  experienceRequired    String?
  education              String?
  benefits               String[]       @default([])
  salary                 Json?
  type                   String?
  priority               String?
  department             String?
  jobCategory            String?
  jobLocationType        String?

  // backend1 legacy salary fields (still used by some existing data)
  salaryMin        Float?
  salaryMax        Float?
  salaryCurrency   String?        @default("USD")
  salaryType       SalaryType?    @default(ANNUAL)
  experienceLevel  String?        // e.g. "Entry-Mid", "Senior", "5+ Years"
  employmentType   EmploymentType @default(FULL_TIME)
  workMode         WorkMode       @default(ON_SITE)
  industry         String?
  aboutRole        String?
  responsibilities String?
  visaSponsorship  Boolean        @default(false)
  isActive         Boolean        @default(true)
  postedAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  company          Company?       @relation(fields: [companyId], references: [id])
  client           Client?        @relation(fields: [clientId], references: [id])

  // Legacy join-table relation (not used by the job-listing endpoint we updated).
  jobSkills       JobSkill[]

  // backendphase2 stores skills as a string array on the job document.
  // backend1 originally used a JobSkill join table; we add a compatible scalar field.
  skills           String[]      @default([])

  applications     Application[]
  savedJobs        SavedJob[]
  aiJobMatches     AiJobMatch[]

  @@map("jobs")
}

model JobSkill {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String   @db.ObjectId
  skillId   String   @db.ObjectId

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id])

  @@unique([jobId, skillId])
  @@map("job_skills")
}

model SavedJob {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String   @db.ObjectId
  jobId       String   @db.ObjectId
  savedAt     DateTime @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("saved_jobs")
}

// ============================================================
// AI JOB MATCH
// ============================================================

model AiJobMatch {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId   String   @db.ObjectId
  jobId         String   @db.ObjectId
  matchScore    Int      // 0-100
  strengths     String[] @default([])
  gaps          String[] @default([])
  cvScore       Int?
  marketFit     Int?     // 0-100
  generatedAt   DateTime @default(now())

  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("ai_job_matches")
}

// ============================================================
// APPLICATIONS
// ============================================================

model Application {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  candidateId      String            @db.ObjectId
  jobId            String            @db.ObjectId
  status           ApplicationStatus @default(SUBMITTED)
  matchScore       Int?              // 0-100
  appliedAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  emailUpdates     Boolean           @default(true)
  whatsappUpdates  Boolean           @default(true)
  offerDetails     String?           // JSON or text when selected
  screeningAnswers Json?             // Screening questions answers

  candidate        Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job              Job               @relation(fields: [jobId], references: [id])
  timeline         ApplicationTimeline[]
  communications   ApplicationCommunication[]

  @@unique([candidateId, jobId])
  @@map("applications")
}

model ApplicationTimeline {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String            @db.ObjectId
  status        ApplicationStatus
  title         String            // e.g. "Submitted", "Under Review"
  description   String?
  occurredAt    DateTime          @default(now())

  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_timelines")
}

model ApplicationCommunication {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String      @db.ObjectId
  channel       String      // "email" | "whatsapp"
  subject       String?
  message       String
  sentAt        DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_communications")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String           @db.ObjectId
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  link        String?
  createdAt   DateTime         @default(now())

  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  duration    String?  // e.g. "2h 15m"
  thumbnailUrl String?
  courseUrl   String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String       @db.ObjectId
  courseId    String       @db.ObjectId
  status      CourseStatus @default(NOT_STARTED)
  progress    Int          @default(0) // 0-100
  enrolledAt  DateTime     @default(now())
  completedAt DateTime?

  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id])

  @@unique([candidateId, courseId])
  @@map("course_enrollments")
}

// ============================================================
// DASHBOARD STATS (Cached / Aggregated)
// ============================================================

model DashboardStats {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId          String   @unique @db.ObjectId
  totalApplications    Int      @default(0)
  activeApplications   Int      @default(0)
  interviews           Int      @default(0)
  savedJobs            Int      @default(0)
  profileCompleteness  Int      @default(0) // 0-100
  cvScore              Int      @default(0) // 0-100
  marketFit            Int      @default(0) // 0-100
  lastUpdated          DateTime @default(now())

  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("dashboard_stats")
}

// ============================================================
// AI PROFILE INSIGHTS
// ============================================================

model AiProfileInsight {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String   @db.ObjectId
  insights    String[] @default([]) // Bullet points from AI
  rolesInDemand    String[] @default([])
  topLocations     String[] @default([])
  skillsToImprove  String[] @default([])
  generatedAt DateTime @default(now())

  @@map("ai_profile_insights")
}

// ============================================================
// CV ANALYSIS
// ============================================================

model CvAnalysis {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId     String   @unique @db.ObjectId
  resumeId        String?  @db.ObjectId
  
  // Scores (0-100)
  cvScore         Int      @default(0) // Final weighted score
  sectionScore    Int      @default(0) // Section completeness
  atsScore        Int      @default(0) // ATS compatibility
  keywordScore    Int      @default(0) // Keyword optimization
  grammarScore    Int      @default(0) // Grammar analysis
  bulletScore     Int      @default(0) // Bullet point quality
  
  // Detailed breakdown
  sectionDetails  Json?    // Which sections are present/missing
  atsDetails      Json?    // ATS compatibility details
  keywordDetails  Json?    // Matched/missing keywords
  grammarDetails  Json?    // Grammar mistakes found
  bulletDetails   Json?    // Bullet point analysis
  
  // Suggestions and mistakes
  suggestions     String[] @default([])
  mistakes        String[] @default([])
  
  // Skills, Experience, Education levels (for dashboard display)
  skillsLevel     String?  // "High", "Good", "Avg", "Low"
  experienceLevel String?  // "High", "Good", "Avg", "Low"
  educationLevel  String?  // "High", "Good", "Avg", "Low"
  
  analyzedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("cv_analyses")
}
