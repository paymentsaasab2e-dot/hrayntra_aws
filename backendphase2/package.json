{
  "name": "saas-recruitment-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for SAAS Recruitment Platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx --ext ts,js src/server.js",
    "start": "tsx src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "create:super-admin": "node scripts/create-super-admin.js",
    "create:role-users": "node scripts/create-role-users.js",
    "disable-password-reset": "node scripts/disable-password-reset.js",
    "seed:team": "tsx src/seeds/teamSeed.ts"
  },
  "keywords": [
    "recruitment",
    "saas",
    "api",
    "express",
    "prisma",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/identity": "^4.8.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^5.19.1",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^148.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.0",
    "openai": "^4.86.1",
    "resend": "^4.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
