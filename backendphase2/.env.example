# MongoDB via Prisma (use your own cluster user/password)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/phase2?retryWrites=true&w=majority"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TEMPLATE_AUTH_OTP=

# JWT (generate strong random strings for production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
PORT=5001
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3001

# Gemini API
GEMINI_API_KEY=

# ── Communication / OAuth (keep ALL of these on the backend only) ──
# AES-256-GCM: 64 hex chars (32 bytes), e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Optional; falls back to JWT_ACCESS_SECRET
OAUTH_STATE_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/v1/oauth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:5001/api/v1/oauth/microsoft/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Legacy job flow callback (if still used):
LINKEDIN_REDIRECT_URI=http://localhost:3001/job
# Settings → Communication LinkedIn OAuth callback (register in LinkedIn app):
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:5001/api/v1/oauth/linkedin/callback
TWILIO_PHONE_NUMBER=

# OpenAI — interview feedback summaries + floating app assistant (get key from platform.openai.com)
OPENAI_API_KEY=
# Optional model for assistant drawer (default: gpt-4o-mini)
OPENAI_ASSISTANT_MODEL=
# DANGEROUS for multi-user: if true, any logged-in user can read all DB rows via the assistant (single-tenant only)
ASSISTANT_FULL_DB_ACCESS=
