// Prisma MongoDB Schema for SAAS Recruitment Platform
// Generated based on frontend analysis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ── ADMINISTRATION & AUTH ──
// Serves: administration, login, team

enum Role {
  SUPER_ADMIN
  ADMIN
  RECRUITER
  MANAGER
  VIEWER
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String    @unique
  passwordHash     String
  role             Role      @default(RECRUITER)
  department       String?
  avatar           String?
  isActive         Boolean   @default(true)
  lastLogin        DateTime?
  otp              String?
  otpExpiry        DateTime?
  refreshToken     String?
  // Extended fields from frontend (team page)
  phone            String?
  joiningDate      DateTime?
  manager          String? // Reporting manager name
  assignedClients  Int? // Count of assigned clients
  assignedJobs     Int? // Count of assigned jobs
  activeCandidates Int? // Count of active candidates
  placements       Int? // Count of placements
  monthlyTarget    Int? // Monthly placement target
  revenueTarget    Float? // Monthly revenue target
  activityTarget   Int? // Monthly activity target
  revenueGenerated Float? // Revenue generated
  commissionEarned Float? // Commission earned
  commissionRate   Float? // Commission rate percentage
  performanceData  Json? // Performance chart data
  
  // New team management fields
  firstName        String?
  lastName         String?
  designation      String?
  location         String?
  status           UserStatus? @default(ACTIVE)
  departmentId     String?     @db.ObjectId
  roleId           String?     @db.ObjectId
  managerId        String?     @db.ObjectId
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  departmentRelation Department?  @relation(fields: [departmentId], references: [id])
  systemRole         SystemRole?  @relation(fields: [roleId], references: [id])
  managerRelation    User?        @relation("UserManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates       User[]        @relation("UserManager")
  credential       UserCredential?
  activities       UserActivity[]
  tasks            TeamTask[]
  targets          TeamTarget[]
  commissions      Commission[]
  assignedCandidates Candidate[]
  createdCandidates  Candidate[]         @relation("CandidateCreator")
  assignedJobsRel    Job[]               @relation("JobAssignee")
  createdJobs        Job[]               @relation("JobCreator")
  assignedLeads      Lead[]
  assignedClientsRel Client[]            @relation("ClientAssignee")
  assignedTasks      Task[]              @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  createdActivities  Activity[]
  scheduledMeetings  ScheduledMeeting[] @relation("ScheduledMeetingCreator")
  cancelledMeetings  ScheduledMeeting[] @relation("ScheduledMeetingCanceller")
  teamMemberships    TeamMember[]
  sentMessages       Message[]
  threadParticipants ThreadParticipant[]
  createdReports     Report[]
  recruitedPlacements   Placement[]             @relation("PlacementRecruiter")
  placementCommissions  PlacementCommission[]   @relation("PlacementCommissionRecruiter")
  uploadedPlacementDocs PlacementDocument[]     @relation("PlacementDocumentUploader")
  placementLogs         PlacementActivityLog[]  @relation("PlacementActivityActor")
  leadInterviews     Interview[]             @relation("InterviewLeadInterviewer")
  createdInterviews  Interview[]             @relation("InterviewCreator")
  interviewPanels    InterviewPanel[]
  interviewFeedbacks InterviewFeedback[]     @relation("InterviewFeedbackAuthor")
  interviewNotes     InterviewNote[]         @relation("InterviewNoteAuthor")
  interviewLogs      InterviewActivityLog[]  @relation("InterviewActivityActor")
  createdMatches     Match[]
  pipelineMovedBy    PipelineEntry[]
  settings           Setting[]
  createdClientNotes ClientNote[]
  createdClientFiles ClientFile[]
  linkedinToken      LinkedInToken?
  createdJobNotes    JobNote[]
  createdJobFiles    JobFile[]
  createdLeadNotes   LeadNote[]
  createdLeadFiles   LeadFile[]
  createdCandidateFiles CandidateFile[]
  createdInterviewFiles InterviewFile[]
  createdTaskFiles   TaskFile[] @relation("TaskFileUploader")
  ownedContacts      Contact[]  @relation("ContactOwner")
  contactNotes       ContactNote[] @relation("ContactNoteAuthor")
  contactActivities  ContactActivity[] @relation("ContactActivityUser")
  assistantPageHistories AssistantPageHistory[]

  userOAuthTokens               UserOAuthTokens?
  userCommunicationPreferences  UserCommunicationPreferences?
  jobBoardIntegrations          JobBoardIntegration[]
  integrationConnections        IntegrationConnection[]

  @@index([role])
  @@map("users")
}

// ── TEAM ──
// Serves: team

model Team {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  teamId    String   @db.ObjectId
  role      String
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

// ── CLIENT ──
// Serves: client

enum ClientStatus {
  ACTIVE
  PROSPECT
  ON_HOLD
  INACTIVE
}

model Client {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  companyName  String // Required: Company name (matches frontend "name" field)
  industry     String? // Industry sector
  website      String? // Company website URL
  logo         String? // Logo image URL
  location     String? // Company location/address
  status       ClientStatus @default(PROSPECT) // ACTIVE, PROSPECT, ON_HOLD, INACTIVE
  assignedToId String?      @db.ObjectId // User ID of assigned account manager/recruiter

  // Extended fields from frontend (Company Snapshot section)
  companySize     String? // Company size (e.g., "1-50", "51-200", "201-500")
  hiringLocations String? // Comma-separated list of hiring locations
  linkedin        String? // LinkedIn company page URL
  timezone        String? // Timezone (e.g., "PST (UTC-8)")
  clientSince     DateTime? // Date when client relationship started (displayed as "Client since")
  servicesNeeded  String? // Services requested by the client
  expectedBusinessValue String? // Expected business value from lead conversion or manual entry
  leadStatus      String? // Source lead/import status for overview display

  // Relationship & Ownership section
  priority        String? // Priority level (High, Medium, Low)
  sla             String? // SLA / Response expectations (e.g., "48h response")
  nextFollowUpDue DateTime? // Next follow-up date

  // Performance metrics (calculated/display fields from drawer)
  avgTimeToFill       String? // Average time to fill positions
  healthStatus        String? // Client health status (Good, Needs attention, At risk)
  revenueGenerated    String? // Total revenue generated (display format: "$28.0k")
  billingTotalRevenue String? // Total billing revenue (display format: "$28.0k")
  billingOutstanding  String? // Outstanding billing amount (display format: "$9.7k")
  billingPaid         String? // Paid billing amount (display format: "$18.3k")

  // Additional fields from drawer that may be calculated or stored
  lastActivity         DateTime? // Last activity timestamp (can be calculated from Activity model)
  staleJobsCount       Int? // Count of stale/aging jobs (can be calculated)
  pendingInvoicesCount Int? // Count of pending invoices (can be calculated)
  billingOverdueCount  Int? // Count of overdue invoices (can be calculated)
  candidatesInProgress Int? // Count of candidates in progress (can be calculated)
  interviewsThisWeek   Int? // Count of interviews this week (can be calculated)
  placementsThisMonth  Int? // Count of placements this month (can be calculated)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Embedded address (flexible JSON structure for address details)
  address Json?

  // Relations
  assignedTo     User?           @relation("ClientAssignee", fields: [assignedToId], references: [id])
  contacts       Contact[] // Client contacts
  jobs           Job[] // Jobs posted by client
  leads          Lead[] // Leads converted to this client
  placements     Placement[] // Placements made for this client
  billingRecords BillingRecord[] // Billing/invoice records
  interviews     Interview[] // Interviews scheduled with client
  notes          ClientNote[] // Client notes
  files          ClientFile[] // Client files/documents
  scheduledMeetings ScheduledMeeting[] // Scheduled meetings/follow-ups
  activities     Activity[] // Activities related to this client (via entityType=CLIENT and entityId)

  @@index([status])
  @@index([assignedToId])
  @@map("clients")
}

// ── CLIENT NOTES & FILES ──
// Serves: client drawer (Notes and Files tabs)

model ClientNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId    String   @db.ObjectId
  title       String
  content     String?
  tags        String[] // HR, Finance, Contract, Feedback
  createdById String   @db.ObjectId
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([clientId])
  @@map("client_notes")
}

model ClientFile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId     String   @db.ObjectId
  fileName     String
  fileType     String // NDA, Contract, SLA, Policy, Invoice, Job Brief
  fileUrl      String?
  uploadedById String   @db.ObjectId
  uploadDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([clientId])
  @@map("client_files")
}

model ScheduledMeeting {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId      String   @db.ObjectId
  scheduledById String   @db.ObjectId
  meetingType   String // Call, WhatsApp, Email, Meeting, Follow-up
  scheduledAt   DateTime // Combined date and time
  reminder      String? // 10 minutes before, 30 minutes before, 1 hour before, 1 day before
  notes         String?
  status        ScheduledMeetingStatus @default(SCHEDULED) // SCHEDULED, COMPLETED, CANCELLED, RESCHEDULED
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelledBy   String?  @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scheduledBy User   @relation("ScheduledMeetingCreator", fields: [scheduledById], references: [id])
  cancelledByUser User? @relation("ScheduledMeetingCanceller", fields: [cancelledBy], references: [id])

  @@index([clientId])
  @@index([scheduledById])
  @@index([scheduledAt])
  @@index([status])
  @@map("scheduled_meetings")
}

enum ScheduledMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// ── CONTACT ──
// Serves: contacts

enum ContactType {
  CANDIDATE
  CLIENT
  HIRING_MANAGER
  INTERVIEWER
  VENDOR
  DECISION_MAKER
  FINANCE
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

model Contact {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  firstName         String
  lastName          String
  email             String              @unique
  phone             String?
  companyId         String?             @db.ObjectId
  designation       String?
  department        String?
  location          String?
  linkedinUrl       String?
  contactType       ContactType         @default(CLIENT)
  status            ContactStatus       @default(ACTIVE)
  ownerId           String?             @db.ObjectId
  avatarUrl         String?
  tags              String[]
  associatedJobIds  String[]            @db.ObjectId
  lastContacted     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  company       Client?                @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner         User?                  @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  notes         ContactNote[]
  activities   ContactActivity[]
  communications ContactCommunication[]

  @@index([companyId])
  @@index([ownerId])
  @@index([contactType])
  @@index([status])
  @@map("contacts")
}

model ContactNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  contactId   String   @db.ObjectId
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  note        String
  authorId    String   @db.ObjectId
  author      User     @relation("ContactNoteAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([contactId])
  @@map("contact_notes")
}

model ContactActivity {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  contactId    String   @db.ObjectId
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activityType String
  description  String
  userId       String   @db.ObjectId
  user         User     @relation("ContactActivityUser", fields: [userId], references: [id])
  timestamp    DateTime @default(now())

  @@index([contactId])
  @@index([timestamp])
  @@map("contact_activities")
}

model ContactCommunication {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  contactId   String   @db.ObjectId
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type        String   // email, call, whatsapp, meeting
  subject     String?
  message     String
  direction   String   // inbound, outbound
  timestamp   DateTime @default(now())

  @@index([contactId])
  @@index([timestamp])
  @@map("contact_communications")
}

// ── CANDIDATE ──
// Serves: candidate, matches, pipeline

enum CandidateStatus {
  NEW
  ACTIVE
  PLACED
  INACTIVE
  BLACKLISTED
}

model Candidate {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  // Legacy Mongo rows may contain nulls; make nullable to prevent Prisma conversion crashes.
  firstName      String?
  lastName       String?
  // Not @unique: MongoDB unique indexes treat many `null` emails as duplicates (E11000).
  // Enforce unique non-null emails in application code (e.g. candidate create/import).
  email          String?
  phone          String?
  linkedIn       String?
  resume         String?
  skills         String[]
  experience     Int?
  currentTitle   String?
  currentCompany String?
  location       String?
  address        String?
  city           String?
  country        String?
  status         CandidateStatus @default(NEW)
  source         String?
  assignedToId   String?         @db.ObjectId
  // Recruiter who created this profile (used for "my candidates" on /candidate)
  createdById    String?         @db.ObjectId
  rating         Int?
  availability   String?
  noticePeriod   String?
  hotlist        Boolean         @default(false)
  avatar         String?
  // Extended fields from frontend
  designation    String? // Current designation
  expectedSalary Int?
  currentSalary  Int?
  education      String?
  certifications String[]
  languages      String[]
  portfolio      String?
  website        String?
  notes          String?
  cvSummary      String?
  cvEducationEntries Json?
  cvWorkExperienceEntries Json?
  cvPortfolioLinks Json?
  preferredLocation String?
  assignedJobs   String[] // Array of job IDs
  stage          String? // Applied, Shortlist, Screening, Interviewing, Offered, Hired, Rejected
  lastActivity   DateTime?
  createdAt      DateTime?
  updatedAt      DateTime?

  // Embedded salary
  salary Json?

  // Relations
  assignedTo      User?           @relation(fields: [assignedToId], references: [id])
  createdBy       User?           @relation("CandidateCreator", fields: [createdById], references: [id])
  interviews      Interview[]
  placements      Placement[]
  matches         Match[]
  pipelineEntries PipelineEntry[]
  files           CandidateFile[]

  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
  @@map("candidates")
}

model CandidateFile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId  String   @db.ObjectId
  fileName     String
  fileType     String   // Resume, Portfolio, Offer, Other
  fileUrl      String?
  uploadedById String   @db.ObjectId
  uploadDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])

  @@index([candidateId])
  @@map("candidate_files")
}

// ── JOB ──
// Serves: job, matches, pipeline

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

model Job {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  description         String?
  requirements        String[]
  skills              String[]
  // Location & classification from CreateJobDrawer
  location            String?
  type                JobType   @default(FULL_TIME)
  status              JobStatus @default(DRAFT)
  // Some legacy rows may exist with `clientId: null` (after schema evolution).
  // Make it optional so listing jobs doesn't crash.
  clientId            String?   @db.ObjectId
  assignedToId        String?   @db.ObjectId
  // User who created this job (used for "my jobs" on /job)
  createdById         String?   @db.ObjectId
  openings            Int       @default(1)
  // Extended fields from frontend (ClientDetailsDrawer Jobs tab)
  overview            String?
  keyResponsibilities String[]
  preferredSkills     String[]
  experienceRequired  String?
  education           String?
  benefits            String[]
  postedDate          DateTime?
  hiringManager       String? // Hiring manager name (from contacts)
  hiringManagerId     String?   @db.ObjectId // Reference to Contact if available
  department          String?
  // UI specific metadata (not yet used in analytics, but stored for completeness)
  jobCategory         String?
  jobLocationType     String? // e.g. On-site, Remote, Hybrid
  hot                 Boolean   @default(false)
  aiMatch             Boolean   @default(false)
  noCandidates        Boolean   @default(false)
  slaRisk             Boolean   @default(false)
  expectedClosureDate DateTime? // Expected closure date from drawer
  jdFileName          String? // Job description file name
  workMode            String? // Onsite, Remote, Hybrid
  priority            String? // Low, Medium, High, Urgent
  visibility          String? // Internal, Public
  distributionPlatforms Json? // Distribution platforms (careerPage, linkedIn, naukri, indeed, internalDatabase)
  supportingRecruiters String[] @default([]) // Array of supporting recruiter user IDs
  applicationFormEnabled Boolean @default(false) // Enable job application form
  applicationFormLogo String? // Logo option: account, company, none
  applicationFormQuestions String[] @default([]) // Array of custom application form questions
  applicationFormNote String? // Note for candidates
  // Legacy documents may contain null timestamps; make optional to avoid Prisma conversion crashes.
  createdAt           DateTime? @default(now())
  updatedAt           DateTime? @updatedAt

  // Embedded salary
  salary Json?

  // Relations
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedTo     User?           @relation("JobAssignee", fields: [assignedToId], references: [id])
  createdBy      User?           @relation("JobCreator", fields: [createdById], references: [id])
  pipelineStages PipelineStage[]
  matches        Match[]
  interviews     Interview[]
  placements     Placement[]
  notes          JobNote[]
  files          JobFile[]

  @@index([status])
  @@index([clientId])
  @@index([assignedToId])
  @@index([createdById])
  @@map("jobs")
}

// ── JOB NOTES & FILES ──
// Serves: job drawer (Notes and Files tabs)

model JobNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId       String   @db.ObjectId
  title       String
  content     String?
  tags        String[] // JD, Requirements, Feedback, Hiring, Other
  createdById String   @db.ObjectId
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([jobId])
  @@map("job_notes")
}

model JobFile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId        String   @db.ObjectId
  fileName     String
  fileType     String // JD, Contract, Offer Letter, Policy, Resume, Other
  fileUrl      String?
  uploadedById String   @db.ObjectId
  uploadDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job        Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([jobId])
  @@map("job_files")
}

// ── LEAD ──
// Serves: leads

enum LeadStatus {
  New
  Contacted
  Qualified
  Converted
  Lost
}

enum LeadSource {
  Website
  LinkedIn
  Email
  Referral
  Campaign
}

enum LeadType {
  Company
  Individual
  Referral
}

enum Priority {
  High
  Medium
  Low
}

model Lead {
  id                     String     @id @default(auto()) @map("_id") @db.ObjectId
  // Primary fields matching frontend
  companyName            String?
  contactPerson          String?
  directorName           String?
  email                  String?
  phone                  String?
  type                   LeadType   @default(Company)
  source                 LeadSource @default(Website)
  status                 LeadStatus @default(New)
  priority               Priority   @default(Medium)
  interestedNeeds        String?
  servicesNeeded         String?
  notes                  String?
  expectedBusinessValue  String?
  // Extended company fields
  industry               String?
  sector                 String?
  companySize            String?
  teamName               String?
  website                String?
  companyLinks           String[]   @default([])
  linkedIn               String?
  location               String?
  // Extended contact fields
  designation            String?
  country                String?
  city                   String?
  // Lead management fields
  campaignName           String?
  campaignLink           String?
  referralName           String?
  sourceWebsiteUrl       String?
  sourceLinkedInUrl      String?
  sourceEmail            String?
  otherDetails           Json?
  lastFollowUp           DateTime?
  nextFollowUp           DateTime?
  lostReason             String? // Reason when marked as lost
  // Relations
  assignedToId           String?    @db.ObjectId
  convertedToClientId    String?    @db.ObjectId
  convertedToCandidateId String?    @db.ObjectId
  convertedAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  assignedTo User?      @relation(fields: [assignedToId], references: [id])
  client     Client?    @relation(fields: [convertedToClientId], references: [id])
  noteList   LeadNote[]
  files      LeadFile[]

  @@index([status])
  @@index([assignedToId])
  @@index([source])
  @@index([type])
  @@map("leads")
}

// ── LEAD NOTES ──
// Serves: lead drawer (Notes tab)

model LeadNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId      String   @db.ObjectId
  title       String
  content     String?
  tags        String[] // HR, Finance, Contract, Feedback
  createdById String   @db.ObjectId
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([leadId])
  @@map("lead_notes")
}

model LeadFile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId       String   @db.ObjectId
  fileName     String
  fileType     String   // Contract, Proposal, Other, etc.
  fileUrl      String?
  uploadedById String   @db.ObjectId
  uploadDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lead        Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedBy  User @relation(fields: [uploadedById], references: [id])

  @@index([leadId])
  @@map("lead_files")
}

// ── PIPELINE ──
// Serves: pipeline

model PipelineStage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  order     Int
  color     String?
  jobId     String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job     Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  entries PipelineEntry[]

  @@index([jobId])
  @@map("pipeline_stages")
}

model PipelineEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  candidateId String   @db.ObjectId
  stageId     String   @db.ObjectId
  jobId       String   @db.ObjectId
  movedAt     DateTime @default(now())
  movedById   String?  @db.ObjectId
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

