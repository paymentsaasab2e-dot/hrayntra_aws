  fileSize     Int?     // File size in bytes
  uploadedById String   @db.ObjectId
  uploadDate   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskFileUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("task_files")
}

enum ActivityEntityType {
  CANDIDATE
  JOB
  CLIENT
  INTERVIEW
  PLACEMENT
  LEAD
  TASK
}

model Activity {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  action        String // Action title (e.g., "Job created", "Payment received")
  description   String? // Action description/details
  performedById String             @db.ObjectId
  entityType    ActivityEntityType // CLIENT, JOB, CANDIDATE, INTERVIEW, PLACEMENT, etc.
  entityId      String? // ID of the related entity (clientId, jobId, etc.)
  category      String? // Category for filtering (Jobs, Candidates, Interviews, Billing, Notes, Files)
  relatedType   String? // Related entity type for linking (job, candidate, invoice, contact, placement)
  relatedLabel  String? // Display label for related entity (e.g., "Senior Software Engineer")
  relatedId     String? // ID of related entity for navigation
  metadata      Json? // Additional metadata
  createdAt     DateTime           @default(now())

  performedBy User    @relation(fields: [performedById], references: [id])
  Client      Client? @relation(fields: [clientId], references: [id])
  clientId    String? @db.ObjectId

