  joiningDate      DateTime? // Actual joining date
  actualJoiningDate DateTime?
  salary           Float?
  salaryOffered    Float?
  fee              Float?
  placementFee     Float?
  feeType          FeeType         @default(FLAT)
  commissionPercentage Float       @default(20)
  revenue          Float?
  status           PlacementStatus @default(PENDING)
  failureReason    String?
