  jobId         String          @db.ObjectId
  clientId      String          @db.ObjectId
  interviewerId String?         @db.ObjectId
  createdById   String?         @db.ObjectId
  scheduledAt   DateTime
  duration      Int             @default(60)
  type          InterviewType   @default(VIDEO)
