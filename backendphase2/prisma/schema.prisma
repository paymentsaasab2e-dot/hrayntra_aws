}

model RolePermission {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String   @db.ObjectId
  permissionId String   @db.ObjectId
  createdAt    DateTime @default(now())

  role       SystemRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserCredential {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @unique @db.ObjectId
  loginId         String    @unique
  hashedPassword  String
  tempPasswordFlag Boolean   @default(true)
  inviteToken     String?
  inviteSentAt    DateTime?
  inviteExpiresAt DateTime?
  lastLoginAt     DateTime?
  failedAttempts  Int       @default(0)
  isLocked        Boolean   @default(false)
  createdBy       String?   @db.ObjectId
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginHistory LoginHistory[]

  @@map("user_credentials")
}

model LoginHistory {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  credentialId String     @db.ObjectId
  ipAddress  String?
  device     String?
  outcome    LoginOutcome
  timestamp  DateTime     @default(now())

  credential UserCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId])
  @@index([timestamp])
  @@map("login_history")
}

model UserActivity {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  action   String
  module   String
  metadata Json?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@index([module])
  @@map("user_activities")
}

model TeamTask {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String     @db.ObjectId
  taskTitle   String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("team_tasks")
}

model TeamTarget {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  targetType String
  targetValue Float
  period     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetType])
  @@map("team_targets")
}

model Commission {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  userId          String          @db.ObjectId
  placementId     String          // Changed from String? to String as per requirements
  commissionAmount Float
  commissionPct   Float
  status          CommissionStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("commissions")
}
