  FEEDBACK_SUBMITTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  CONFIRMED
}

enum PanelRole {
  HR
  TECHNICAL
  CLIENT
  HIRING_MANAGER
}

