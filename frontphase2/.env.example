NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
NEXT_PUBLIC_API_BASE=http://localhost:5001

# Public backend origin for “register this redirect URI” hints (production)
NEXT_PUBLIC_BACKEND_PUBLIC_URL=

# Backend PDF proxy (same as API base, must include /api/v1)
BACKEND_INTERNAL_URL=http://localhost:5001/api/v1

# Optional fallback if backend is down (same Cloudinary vars as backend — never commit real secrets)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
